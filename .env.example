# ============================================================
#  Agente Estudos — variáveis de ambiente
#  Copie para .env e preencha os valores.
#  Alternativa ao config.yaml — use um ou outro.
# ============================================================

# Provider ativo: anthropic | openai | groq | ollama
LLM_PROVIDER=anthropic

# ── Anthropic ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL=claude-opus-4-8

# ── OpenAI ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── Groq ─────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# ── Ollama (local) ───────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:latest

# ── Transcrição de vídeo local ───────────────────────────────
# auto | groq | local | none
TRANSCRIPTION_PROVIDER=auto
TRANSCRIPTION_GROQ_API_KEY=
TRANSCRIPTION_LOCAL_MODEL=base

# ── Busca web ────────────────────────────────────────────────
SEARCH_MAX_RESULTS=5
